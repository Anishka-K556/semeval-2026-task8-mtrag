"task_C": {
    "model_name": "google/flan-t5-large",
    "token_limits": {
        "max_input_tokens": 1024,
        "max_new_tokens": 60
    },
    "generation": {
        "num_beams": 3,
        "no_repeat_ngram_size": 3,
        "length_penalty": 1.0,
        "early_stopping": true
    },
    "top_k_context": 3,
    "paths": {
        "query_task_path": "{base}/results/final_submission_taskA.jsonl",
        "output_path": "{base}/results/final_results_taskC.jsonl",
        "corpus_paths": [
            "{base}/corpus/clapnq.jsonl",
            "{base}/corpus/cloud.jsonl",
            "{base}/corpus/fiqa.jsonl",
            "{base}/corpus/govt.jsonl"
        ]
    },
    "prompt_template": "Task: Provide a factual answer using ONLY the SOURCES. If the answer is not in the sources, reply exactly: \"I'm sorry, but I don't have the answer to your question.\"\n\n{context}\n\nQuestion: {query}\n\nAnswer: Based on the sources,",
    "anchor_phrase": "Based on the sources,",
    "strip_prefixes": [
        "Based on the sources,",
        "Answer:",
        "Agent:",
        "User:",
        "SOURCE:"
    ],
    "cant_answer_phrases": [
        "i'm sorry, but i don't have",
        "i don't have the answer",
        "not in the sources",
        "cannot find",
        "no information"
    ],
    "cant_answer_canonical": "I don't know"
}
}
